#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["pynput"]
# ///

import logging
import subprocess
import sys

from pynput import keyboard  # type: ignore

seqs = sorted(zip(sys.argv[1::2], sys.argv[2::2]), key=lambda p: len(p[0]))
buffer = ""


def on_press(key):
    global buffer
    buffer = (buffer + (getattr(key, "char", None) or ""))[-30:]

    for seq, cmd in seqs:
        if buffer.endswith(seq):
            logging.info(cmd)
            subprocess.run(cmd, shell=True)
            buffer = ""
            break


with keyboard.Listener(on_press=on_press) as listener:
    listener.join()
