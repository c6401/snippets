#!/usr/bin/env python3
import sys
import tkinter as tk


def sel(items):
    root = tk.Tk()
    root.geometry("600x400")
    root.attributes("-topmost", True)

    var = tk.StringVar()
    result = None
    filtered = items[:]

    entry = tk.Entry(root, textvariable=var, font=("Courier New", 12))
    entry.pack(fill=tk.X, padx=5, pady=5)
    frame = tk.Frame(root)
    frame.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
    sb = tk.Scrollbar(frame)
    sb.pack(side=tk.RIGHT, fill=tk.Y)
    lb = tk.Listbox(frame, yscrollcommand=sb.set, font=("Courier New", 11))
    lb.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
    sb.config(command=lb.yview)

    def refresh(*_):
        nonlocal filtered
        q = var.get().lower()
        filtered = [i for i in items if all(w in i.lower() for w in q.split())]
        lb.delete(0, tk.END)
        for item in filtered:
            lb.insert(tk.END, item)
        if filtered:
            lb.selection_set(0)
            lb.activate(0)

    def move(delta, *_):
        cur = lb.curselection()
        n = (cur[0] if cur else -1) + delta
        if 0 <= n < len(filtered):
            lb.selection_clear(0, tk.END)
            lb.selection_set(n)
            lb.activate(n)
            lb.see(n)

    def select(*_):
        nonlocal result
        cur = lb.curselection()
        if cur:
            result = filtered[cur[0]]
        root.quit()

    var.trace_add("write", refresh)
    entry.bind("<Return>", select)
    entry.bind("<Escape>", lambda *_: root.quit())
    entry.bind("<Down>", lambda *_: move(1))
    entry.bind("<Up>", lambda *_: move(-1))
    lb.bind("<Return>", select)
    lb.bind("<Double-Button-1>", select)

    refresh()
    entry.focus()
    root.mainloop()
    root.destroy()
    return result


lines = sorted(sys.stdin.read().strip().split("\n")) if not sys.stdin.isatty() else []
print(sel(lines) or '')
